{
  "manifest_version": 3,
  "name": "UnCopy",
  "version": "1.1.0",
  "description": "Copy visible text and readable article text, then manage local copy history.",
  "permissions": ["activeTab", "scripting", "storage", "tabs", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/UncopyLogo-16.png",
    "32": "icons/UncopyLogo-32.png",
    "48": "icons/UncopyLogo-48.png",
    "128": "icons/UncopyLogo-128.png"
  },
  "action": {
    "default_title": "UnCopy",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/UncopyLogo-16.png",
      "32": "icons/UncopyLogo-32.png",
      "48": "icons/UncopyLogo-48.png",
      "128": "icons/UncopyLogo-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/lib/readability.js", "src/content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "minimum_chrome_version": "114"
}
